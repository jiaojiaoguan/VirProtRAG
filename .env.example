# ============================================================
#  VirProtRAG Configuration Template
#  ============================================================
#  Usage:
#    cp .env.example .env
#    vim .env    ← uncomment and fill in your own values
#  ============================================================

# ============================================================
#  1. LLM Provider (required — pick one and uncomment)
# ============================================================

# --- Recommended: DeepSeek (low cost, strong performance) ---
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=sk-your-deepseek-key
# Base URL auto-detected as https://api.deepseek.com
# No need to set LLM_BASE_URL manually!

# --- OpenAI ---
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your-openai-key

# --- Anthropic ---
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# --- Zhipu GLM ---
# LLM_PROVIDER=zhipu
# ZHIPU_API_KEY=your-zhipu-key
# Base URL auto-detected as https://open.bigmodel.cn/api/paas/v4
# No need to set LLM_BASE_URL manually!

# ============================================================
#  2. LLM Model & Advanced Options (optional)
# ============================================================

# --- Specify model (recommended) ---
# One variable for all tasks (gpt-4.1, o3-mini, deepseek-reasoner, etc.)
# LLM_MODEL=gpt-4.1

# --- Custom API endpoint (only needed for proxies/VPNs) ---
# Do NOT set when connecting directly to DeepSeek/Zhipu/OpenAI/Anthropic!
# LLM_BASE_URL=https://your-proxy.example.com/v1

# --- Per-task model overrides (advanced) ---
# Leave unset to use provider defaults or LLM_MODEL
# LLM_SYNONYM_MODEL=deepseek-chat       # synonym expansion (lightweight)
# LLM_EVIDENCE_MODEL=deepseek-chat      # evidence classification (lightweight)
# LLM_GENERATION_MODEL=deepseek-chat    # function annotation (core task)

# ============================================================
#  3. PubMed / NCBI (required)
# ============================================================

# Email is mandatory for PubMed API access
ENTREZ_EMAIL=your-email@example.com

# API key boosts rate limit from 3/s to 10/s (strongly recommended)
# Get one at: https://account.ncbi.nlm.nih.gov/settings/
# ENTREZ_API_KEY=your-ncbi-api-key

# ============================================================
#  4. MedCPT Semantic Retrieval (optional)
# ============================================================
# Works without it (use --skip-dense to disable)
# Download: ftp.ncbi.nlm.nih.gov/pub/lu/MedCPT/pubmed_embeddings/
# MEDCPT_FAISS_INDEX_PATH=/data/MedCPT_faiss.index
# MEDCPT_PMIDS_PATH=/data/MedCPT_pmids.json

# ============================================================
#  5. OpenAlex Paper Quality Scoring (optional)
# ============================================================
# Works without it (use --skip-quality to disable)
# Register at: https://openalex.org/
# OPENALEX_EMAIL=your-email@example.com

# ============================================================
#  6. Cross-Protein Cache (optional but recommended)
# ============================================================
# Avoids redundant API calls when processing multiple proteins
# VIRPROTRAG_CACHE=./virprotrag_cache.json

# ============================================================
#  7. DIAMOND BLASTP (optional — only needed for annotate-seq)
# ============================================================
# DIAMOND_PATH=/usr/local/bin/diamond
